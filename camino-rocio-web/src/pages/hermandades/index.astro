---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Buscador from '../../components/Buscador.svelte';
import { api } from '../../lib/api';

let hermandades = [];
let provincias: string[] = [];

try {
  [hermandades, provincias] = await Promise.all([api.hermandades(), api.provincias()]);
} catch {
  // API no disponible en build — las islas cargan en cliente
}
---

<BaseLayout title="Hermandades" description="Directorio de hermandades filiales de la Romería del Rocío.">
  <div class="container page">
    <header class="page-header">
      <h1>Hermandades</h1>
      <p>Directorio de hermandades filiales que peregrinan anualmente al Rocío.</p>
    </header>

    <Buscador
      client:load
      hermandades={hermandades}
      provincias={provincias}
    />
  </div>
</BaseLayout>

<style>
  .page {
    padding: 2.5rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 0.4rem;
  }

  .page-header p {
    color: var(--color-muted);
  }
</style>
