---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Camino al Rocío',
  description = 'Guía completa de la Romería de El Rocío: hermandades, camino y fechas.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Camino al Rocío</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">
          <span class="logo-symbol">✦</span>
          Camino al Rocío
        </a>
        <nav>
          <a href="/hermandades">Hermandades</a>
          <a href="/camino">El Camino</a>
          <a href="/sobre-la-romeria">La Romería</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Camino al Rocío · Proyecto de portfolio · Gonzalo Trillo Hidalgo</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    background: var(--color-primary);
    color: #fff;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: bold;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .logo:hover { text-decoration: none; opacity: 0.9; }

  .logo-symbol { color: var(--color-gold); font-size: 1rem; }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    font-weight: 500;
  }

  nav a:hover {
    color: #fff;
    text-decoration: none;
  }

  .site-footer {
    margin-top: 4rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
